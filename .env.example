# Copy this file to .env and adjust the values for your environment.
# docker-compose.yml reads these variables automatically.

# S3 / MinIO connection
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false
S3_REGION=us-east-1
# Public URL used in returned presigned links (optional).
# Example (remote): https://s3.example.com
# Example (local):  http://localhost:9000
S3_PUBLIC_URL=

# Public base URL of the Kipup web entry (optional).
# When set, "Generate Download link" will return a shareable proxy URL like:
#   https://kipup.example.com/api/download?url=<presigned>&filename=...
PUBLIC_BASE_URL=

# Go backend listen address (container-internal)
LISTEN_ADDR=:8080

# Bootstrap admin account for sign in
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# JSON persistence file for tasks/history/policies/webhooks
DATA_FILE=./data/state.json

# Background cleanup interval in seconds
CLEANUP_INTERVAL_SECONDS=3600
