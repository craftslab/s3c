# Copy this file to .env and adjust the values for your environment.
# docker-compose.yml reads these variables automatically.

# S3 / MinIO connection
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false
S3_REGION=us-east-1
# Public URL used in returned presigned links (optional).
# Example (remote): https://s3.example.com
# Example (local):  http://localhost:9000
S3_PUBLIC_URL=

# Public base URL of the S3C web entry (optional).
# When set, "Generate Download link" will return a shareable proxy URL like:
#   https://s3c.example.com/api/download?url=<presigned>&filename=...
PUBLIC_BASE_URL=

# Go backend listen address (container-internal)
LISTEN_ADDR=:8080
